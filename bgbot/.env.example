# ═══════════════════════════════════════
#  BG-BOT v5 — Environment Variables
# ═══════════════════════════════════════

# Flask Secret Key (change in production!)
SECRET_KEY=change-this-to-random-string

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Encryption key for API secrets (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPT_KEY=

# Server
PORT=5000
